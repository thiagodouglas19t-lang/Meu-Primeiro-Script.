local function CriarAba(nome, id)
    local FrameAba = Instance.new("ScrollingFrame")
    FrameAba.Size = UDim2.new(1, 0, 1, 0)
    FrameAba.BackgroundTransparency = 1
    FrameAba.Visible = (id == 1)
    FrameAba.CanvasSize = UDim2.new(0, 0, 1.8, 0)
    FrameAba.ScrollBarThickness = 3
    FrameAba.Parent = ContentContainer
    
    local ListLayout = Instance.new("UIListLayout")
    ListLayout.Padding = UDim.new(0, 8)
    ListLayout.Parent = FrameAba
    
    local BotaoAba = Instance.new("TextButton")
    BotaoAba.Size = UDim2.new(1, -10, 0, 35)
    BotaoAba.Position = UDim2.new(0, 5, 0, (id-1)*40 + 5)
    BotaoAba.BackgroundColor3 = (id == 1) and Color3.fromRGB(25, 25, 35) or Color3.fromRGB(20, 20, 28)
    BotaoAba.Text = nome
    BotaoAba.TextColor3 = Color3.fromRGB(255, 255, 255)
    BotaoAba.TextSize = 13
    BotaoAba.Font = Enum.Font.SourceSansBold
    BotaoAba.Parent = TabContainer
    
    local BCorner = Instance.new("UICorner")
    BCorner.CornerRadius = UDim.new(0, 6)
    BCorner.Parent = BotaoAba
    
    Abas[nome] = {Frame = FrameAba, Botao = BotaoAba}
    pages[nome] = FrameAba
    
    BotaoAba.MouseButton1Click:Connect(function()
        for _, v in pairs(Abas) do
            v.Frame.Visible = false
            v.Botao.BackgroundColor3 = Color3.fromRGB(20, 20, 28)
        end
        FrameAba.Visible = true
        BotaoAba.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    end)
    return FrameAba
end

-- Botões estilizados em formato de listas/toggles horizontais do Redz
local function CriarToggle(abaFrame, texto, callback)
    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Size = UDim2.new(1, -10, 0, 40)
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    ToggleBtn.Text = "  " .. texto .. " : [OFF]"
    ToggleBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    ToggleBtn.TextSize = 14
    ToggleBtn.Font = Enum.Font.SourceSans
    ToggleBtn.TextXAlignment = Enum.TextXAlignment.Left
    ToggleBtn.Parent = abaFrame
    
    local TCorner = Instance.new("UICorner")
    TCorner.CornerRadius = UDim.new(0, 6)
    TCorner.Parent = ToggleBtn
    
    local ativo = false
    ToggleBtn.MouseButton1Click:Connect(function()
        ativo = not ativo
        if ativo then
            ToggleBtn.BackgroundColor3 = Color3.fromRGB(30, 45, 35)
            ToggleBtn.Text = "  " .. texto .. " : [ON]"
            ToggleBtn.TextColor3 = Color3.fromRGB(100, 255, 100)
        else
            ToggleBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
            ToggleBtn.Text = "  " .. texto .. " : [OFF]"
            ToggleBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
        callback(ativo)
    end)
end

