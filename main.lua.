local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Carrega a Biblioteca Oficial Orion (Que o Delta aceita nativamente)
local OrionLib = loadstring(game:HttpGet(('https://githubusercontent.com')))()

-- Cria a Janela Principal estilo Redz Hub
local Window = OrionLib:MakeWindow({
    Name = "SHARK HUB v5.0 | Redz Style", 
    HidePremium = false, 
    SaveConfig = false, 
    IntroText = "Carregando Shark Hub..."
})

-- Estados de repetição (Loops)
local state = { autoMove = false, targetLock = false, chestEsp = false, itemEsp = false }

-- =======================================================
-- ABA 1: EVENTOS DO MAR
-- =======================================================
local MarTab = Window:MakeTab({ Name = "Eventos do Mar", Icon = "rbxassetid://4483345998" })

MarTab:AddToggle({
    Name = "Navegacao Auto (Ate Zona 5)",
    Default = false,
    Callback = function(Value)
        state.autoMove = Value
    end
})

task.spawn(function()
    while task.wait(0.15) do
        if state.autoMove then
            pcall(function()
                local seat = LocalPlayer.Character and LocalPlayer.Character.Humanoid.SeatPart
                if seat and seat.Parent:IsA("Model") then
                    seat.Parent:TranslateBy(seat.CFrame.LookVector * 4)
                end
            end)
        end
    end
end)

MarTab:AddToggle({
    Name = "Auto Matar (Focar Terror/Sea)",
    Default = false,
    Callback = function(Value)
        state.targetLock = Value
    end
})

local function findTarget()
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local nearest, nearestDist = nil, math.huge
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj.Name ~= "Leviathan" then
            if obj.Name == "Terror Shark" or obj.Name == "Sea Beast" or obj.Name == "Ghost Ship" then
                local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                if part then
                    local dist = (root.Position - part.Position).Magnitude
                    if dist < nearestDist then
                        nearest = part
                        nearestDist = dist
                    end
                end
            end
        end
    end
    return nearest
end

task.spawn(function()
    while task.wait(0.2) do
        if state.targetLock then
            pcall(function()
                local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                local target = findTarget()
                if root and target then
                    root.CFrame = CFrame.new(target.Position + Vector3.new(0, 32, 0), target.Position)
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton1(Vector2.new(0, 0))
                end
            end)
        end
    end
end)

-- =======================================================
-- ABA 2: IR PARA ILHAS
-- =======================================================
local IlhasTab = Window:MakeTab({ Name = "Ir para Ilhas", Icon = "rbxassetid://4483345998" })

workspace.ChildAdded:Connect(function(obj)
    if obj.Name == "Mirage Island" or obj.Name == "Kitsune Island" then
        OrionLib:MakeNotification({ Name = "Ilha Detectada!", Content = obj.Name .. " surgiu no servidor!", Time = 5 })
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = obj:GetModelCFrame() * CFrame.new(0, 80, 0)
        end
    end
end)

IlhasTab:AddLabel("O script teletransporta automaticamente se a ilha nascer.")

-- =======================================================
-- ABA 3: VISUAIS & ESP
-- =======================================================
local EspTab = Window:MakeTab({ Name = "Visuais & ESP", Icon = "rbxassetid://4483345998" })

local function addBox(obj, color)
    if obj:FindFirstChild("TestESPBox") then return end
    local part = obj:IsA("BasePart") and obj or (obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart"))) or (obj:IsA("Tool") and obj:FindFirstChildWhichIsA("BasePart"))
    if not part then return end
    local box = Instance.new("BoxHandleAdornment")
    box.Name = "TestESPBox"
    box.Adornee = part
    box.AlwaysOnTop = true
    box.ZIndex = 10
    box.Size = part.Size + Vector3.new(0.5, 0.5, 0.5)
    box.Transparency = 0.35
    box.Color3 = color
    box.Parent = part
end

EspTab:AddToggle({
    Name = "ESP Berry (Ver Baus de Ouro)",
    Default = false,
    Callback = function(Value) state.chestEsp = Value end
})

EspTab:AddToggle({
    Name = "Notificador de Frutas no Chao",
    Default = false,
    Callback = function(Value) state.itemEsp = Value end
})

task.spawn(function()
    while task.wait(2) do
        if state.chestEsp then
            for _, obj in ipairs(workspace:GetChildren()) do
                if string.find(string.lower(obj.Name), "chest") or string.find(string.lower(obj.Name), "bau") then
                    addBox(obj, Color3.fromRGB(255, 230, 0))
                end
            end
        end
        if state.itemEsp then
            for _, obj in ipairs(workspace:GetChildren()) do
                if obj:IsA("Tool") and string.find(string.lower(obj.Name), "fruit") then
                    addBox(obj, Color3.fromRGB(255, 80, 200))
                end
            end
        end
    end
end)

-- =======================================================
-- ABA 4: OTIMIZAR JOGO
-- =======================================================
local OtimizarTab = Window:MakeTab({ Name = "Otimizar Jogo", Icon = "rbxassetid://4483345998" })

OtimizarTab:AddButton({
    Name = "Remover Texturas (Mais FPS)",
    Callback = function()
        local count = 0
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Texture") or obj:IsA("Decal") then
                obj:Destroy()
                count = count + 1
            end
        end
        OrionLib:MakeNotification({ Name = "Anti-Lag", Content = "Texturas removidas: " .. tostring(count), Time = 3 })
    end
})

OtimizarTab:AddToggle({
    Name = "Modo Boost: Tela Preta",
    Default = false,
    Callback = function(Value)
        pcall(function() RunService:Set3dRenderingEnabled(not Value) end)
    end
})

OrionLib:Init()
