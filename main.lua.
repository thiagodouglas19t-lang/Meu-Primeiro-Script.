local EspBeryAtivo = false
local NotificadorFruta = false

local function CriarEsp(objeto, cor, texto)
    if objeto:FindFirstChild("EspIdentificador") then return end
    local Box = Instance.new("BoxHandleAdornment")
    Box.Name = "EspIdentificador"
    Box.Size = objeto:IsA("Model") and (objeto.PrimaryPart and objeto.PrimaryPart.Size or Vector3.new(4,4,4)) or objeto.Size
    Box.AlwaysOnTop = true
    Box.ZIndex = 5
    Box.Color3 = cor
    Box.Adornee = objeto
    Box.Transparency = 0.4
    Box.Parent = objeto
end

