-- =======================================================
-- 2. FUNÇÃO QUE ABRE O PAINEL PRINCIPAL APÓS O LOADING
-- =======================================================
local function AbrirPainelPrincipal()
    local MainGui = Instance.new("ScreenGui")
    MainGui.Name = "MeuPainelPrincipal"
    MainGui.Parent = CoreGui

    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.new(0, 300, 0, 250)
    MainFrame.Position = UDim2.new(0.1, 0, 0.3, 0) -- Fica no canto esquerdo da tela
    MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    MainFrame.BorderSizePixel = 0
    MainFrame.Active = true
    MainFrame.Draggable = true -- Permite arrastar o painel pela tela
    MainFrame.Parent = MainGui

    local MainCorner = Instance.new("UICorner")
    MainCorner.CornerRadius = UDim.new(0, 10)
    MainCorner.Parent = MainFrame

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, 0, 0, 40)
    Title.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    Title.TextColor3 = Color3.fromRGB(0, 200, 255)
    Title.TextSize = 20
    Title.Font = Enum.Font.SourceSansBold
    Title.Text = "SHARK HUB v1.0"
    Title.Parent = MainFrame
    
    local TitleCorner = Instance.new("UICorner")
    TitleCorner.CornerRadius = UDim.new(0, 10)
    TitleCorner.Parent = Title

    -- Botão de Auto Click (Atacar)
    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(0, 240, 0, 45)
    Button.Position = UDim2.new(0.5, -120, 0.4, 0)
    Button.BackgroundColor3 = Color3.fromRGB(255, 50, 50) -- Começa Vermelho (Desativado)
    Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    Button.TextSize = 18
    Button.Font = Enum.Font.SourceSansBold
    Button.Text = "Auto Clicker: DESATIVADO"
    Button.Parent = MainFrame

    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 8)
    ButtonCorner.Parent = Button

    -- Lógica de funcionamento do Botão (Ligar/Desligar)
    local AutoClickAtivo = false
    
    Button.MouseButton1Click:Connect(function()
        AutoClickAtivo = not AutoClickAtivo
        
        if AutoClickAtivo then
            Button.BackgroundColor3 = Color3.fromRGB(50, 200, 50) -- Muda para Verde
            Button.Text = "Auto Clicker: ATIVADO"
            
            -- Cria a rotina de ataque em segundo plano
            task.spawn(function()
                while AutoClickAtivo do
                    task.wait(0.1) -- Velocidade dos cliques (0.1 segundos)
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton1(Vector2.new(0, 0))
                end
            end)
        else
            Button.BackgroundColor3 = Color3.fromRGB(255, 50, 50) -- Volta para Vermelho
            Button.Text = "Auto Clicker: DESATIVADO"
        end
    end)
end

-- =======================================================
-- 3. EXECUÇÃO DA ANIMAÇÃO DO LOADING
-- =======================================================
task.spawn(function()
    StatusText.Text = "Verificando arquivos..."
    BarFill:TweenSize(UDim2.new(0.3, 0, 1, 0), "Out", "Quad", 1)
    task.wait(1.2)

    StatusText.Text = "Conectando ao servidor..."
    BarFill:TweenSize(UDim2.new(0.7, 0, 1, 0), "Out", "Quad", 1.5)
    task.wait(1.7)

    StatusText.Text = "Injetando Shark Hub..."
    BarFill:TweenSize(UDim2.new(1, 0, 1, 0), "Out", "Quad", 0.8)
    task.wait(1)

    -- Fecha o loading de forma suave sumindo com ele
    LoadingGui:Destroy()
    
    -- Abre o painel do cheat
    AbrirPainelPrincipal()
end)
