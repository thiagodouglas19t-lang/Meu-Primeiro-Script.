local function addBox(obj, color)
	if obj:FindFirstChild("TestESPBox") then return end
	local part = nil
	if obj:IsA("BasePart") then part = obj
	elseif obj:IsA("Model") then part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
	elseif obj:IsA("Tool") then part = obj:FindFirstChildWhichIsA("BasePart") end
	if not part then return end

	local box = Instance.new("BoxHandleAdornment")
	box.Name = "TestESPBox"
	box.Adornee = part
	box.AlwaysOnTop = true
	box.ZIndex = 10
	box.Size = part.Size + Vector3.new(0.5, 0.5, 0.5)
	box.Transparency = 0.35
	box.Color3 = color
	box.Parent = part
end

